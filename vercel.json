{
    "version": 2,
    "buildCommand": "npm run build:vercel",
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build"
        },
        {
            "src": "server/api/chat.py",
            "use": "@vercel/python"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/server/api/chat.py"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}