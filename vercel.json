{
    "version": 2,
    "buildCommand": "npm run build:vercel",
    "installCommand": "npm install && ./install_uv.sh",
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build"
        },
        {
            "src": "server/index.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": "server/python_modules/**"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/server/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}